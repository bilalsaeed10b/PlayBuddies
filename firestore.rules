// Bilal Saeed 123
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Users ───
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // ─── Friend Connections ───
    match /connections/{connId} {
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.participants;
      allow delete: if request.auth != null
                    && request.auth.uid in resource.data.participants;
    }

    // ─── Invites ───
    match /invites/{inviteId} {
      allow read: if request.auth != null
                  && request.auth.uid == resource.data.targetId;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.fromUid;
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.targetId;
      allow update: if false;
    }

    // ─── Lobbies (serves as the single source for platform + game) ───
    match /lobbies/{lobbyId} {
      allow read: if request.auth != null;

      // Anyone authenticated can create a lobby
      allow create: if request.auth != null
                    && request.resource.data.hostId == request.auth.uid
                    && request.resource.data.players.size() <= 8;

      // Host can update settings/status; players can only modify the players array
      allow update: if request.auth != null
                    && (
                      // Host can do anything
                      resource.data.hostId == request.auth.uid
                      ||
                      // Non-host can only update the players array (join/leave)
                      (
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['players', 'updatedAt', 'messages'])
                        && request.resource.data.players.size() <= 8
                      )
                    );

      // Only host can delete a lobby
      allow delete: if request.auth != null
                    && resource.data.hostId == request.auth.uid;
    }

    // ─── Game Rooms (legacy — kept for existing game engine compatibility) ───
    match /rooms/{roomId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
// Bilal Saeed 123
