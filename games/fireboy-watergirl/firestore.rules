rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: rooms
    // Document ID: {roomId}
    // Fields:
    //   - roomId: string (required) - unique room code
    //   - status: string (required, enum: ['lobby', 'playing']) - room state
    //   - level: number (required) - current level index
    //   - players: map (required) - map of player data keyed by UID
    //   - chat: array (optional) - list of chat messages
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidRoom(data) {
      return data.roomId is string && data.roomId.size() > 0 && data.roomId.size() < 20 &&
             data.status in ['lobby', 'playing'] &&
             data.level is number && data.level >= 0 &&
             data.players is map && data.players.keys().size() <= 4;
    }

    match /rooms/{roomId} {
      // Allow anyone to read a room if they know the ID
      allow read: if true;
      
      // Allow authenticated users to create or update rooms
      allow create: if isAuthenticated() && isValidRoom(request.resource.data);
      
      // Allow updates if the data is valid
      allow update: if isAuthenticated() && isValidRoom(request.resource.data);
      
      // No deletions allowed via client
      allow delete: if false;

      match /updates/{playerId} {
        // Allow anyone to read player updates in this room
        allow read: if true;
        
        // Allow a player to update their own position/state
        // In a real app, we'd check if the user is in the room, but for a game lobby, 
        // we'll allow updates to join/leave/update state.
        allow create, update: if isAuthenticated() && request.auth.uid == playerId;
        
        // No deletions allowed via client
        allow delete: if false;
      }
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
